# ── GrindBoard configuration ────────────────────────────────────────────────
#
# In production, the React app talks ONLY to our own /api/* serverless routes;
# those routes talk to the upstream LeetCode API and cache in Redis. So most of
# these are SERVER-side (set them in Vercel Project Settings → Environment
# Variables, or in .env for `vercel dev`). They are NOT exposed to the browser.

# ── Storage: Upstash Redis (NOT @vercel/kv, which is sunset) ─────────────────
# Provision via Vercel Dashboard → Storage → Marketplace → "Upstash for Redis"
# and link it to the project — it auto-injects the KV_REST_API_* pair below.
# Either naming convention works; the app reads whichever pair is present.
#
# If NEITHER pair is set, the app still runs: no caching, roster = committed
# defaults only (the in-app local fallback also remains available).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ...or the names the Vercel integration injects:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Upstream LeetCode API (server-only) ─────────────────────────────────────
# Where the serverless functions fetch from. Point this at your OWN alfa
# instance to self-host. The browser never touches this directly anymore.
# Default: https://alfa-leetcode-api.onrender.com
ALFA_API_BASE=https://alfa-leetcode-api.onrender.com

# ── Caching ─────────────────────────────────────────────────────────────────
# Per-user stats cache TTL in seconds. Default 600 (10 minutes).
CACHE_TTL_SECONDS=600

# ── Write protection (optional) ─────────────────────────────────────────────
# If set, roster writes (POST/DELETE /api/roster) require header
# `x-admin-token: <this value>`. If unset, writes are open (fine for a small
# friend group). GET routes are always public.
ADMIN_TOKEN=

# Optional secret for the daily snapshot cron (Authorization: Bearer <secret>).
# Vercel injects this when you set it; the /api/snapshot route accepts either
# ADMIN_TOKEN or CRON_SECRET.
CRON_SECRET=

# ── Cross-origin access (optional) ──────────────────────────────────────────
# The deployed UI calls its own /api SAME-ORIGIN and never needs CORS. Reads
# (GET) are public to any origin. Cross-origin WRITES (POST/DELETE /api/roster)
# are only permitted from origins listed here (comma-separated, exact match
# incl. scheme, e.g. https://app.example.com,https://staging.example.com).
# Leave unset unless you serve the frontend from a DIFFERENT origin than /api;
# when unset, browsers block cross-origin roster writes outright.
ALLOWED_ORIGINS=

# ── Local fallback only (build-time, browser-exposed) ───────────────────────
# Used ONLY when the app runs without /api (e.g. plain `vite`, or `vite
# preview`): the in-app local mode fetches alfa directly from this base. The
# in-app "API base" field overrides it at runtime. Irrelevant in production.
VITE_API_BASE=https://alfa-leetcode-api.onrender.com
